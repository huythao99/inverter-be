# API URL for the backend
# For development:
VITE_API_URL=http://localhost:3000
# For production:
# VITE_API_URL=https://giabao-inverter.com

# MQTT WebSocket URL for real-time data
# Mosquitto must have WebSocket listener enabled (port 9001)
# For development:
VITE_MQTT_WS_URL=ws://localhost:9001
# For production:
# VITE_MQTT_WS_URL=wss://giabao-inverter.com:9001

# MQTT credentials (same as backend MQTT user)
VITE_MQTT_USERNAME=giabao
VITE_MQTT_PASSWORD=0918273645
